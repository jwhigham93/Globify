# Normalize line endings to LF on commit (prevents CRLF noise from Windows/WSL checkouts)
* text=auto eol=lf

# Binaries — never diff or convert
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.wasm binary
*.zip binary
*.tar.gz binary
*.tgz binary
*.pdf binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
